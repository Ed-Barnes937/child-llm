DATABASE_URL=postgres://childsafe:childsafe@localhost:5433/childsafe
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=dev-secret-change-in-prod-at-least-32-chars
PIPELINE_URL=http://localhost:3001
PIPELINE_API_KEY=dev-pipeline-key
OPENROUTER_API_KEY=

# Behavioural rate limiting (phase 6.5.6). MEDIUM-CONFIDENCE layer: these are
# starting points, NOT validated figures — tune them against real traffic.
# Each is optional; the app falls back to the default shown if unset.
# Session velocity (per child): max messages per window.
RATE_LIMIT_VELOCITY_WINDOW_S=60
RATE_LIMIT_MAX_MESSAGES=20
# Repeated-probe (per child): max guardrail-tripping messages per window.
RATE_LIMIT_PROBE_WINDOW_S=300
RATE_LIMIT_MAX_PROBES=4
# Device reputation: max probes accrued across a device per window.
RATE_LIMIT_REPUTATION_WINDOW_S=3600
RATE_LIMIT_DEVICE_PROBE_STRIKES=8
# PIN brute-force lockout (per child).
RATE_LIMIT_PIN_WINDOW_S=900
RATE_LIMIT_MAX_PIN_FAILURES=5
# How long behavioural signals are retained before pruning (>= every window).
RATE_LIMIT_RETENTION_S=86400
